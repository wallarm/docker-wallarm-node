#!/bin/bash

configure_nginx() {

  if [ -n "$POSTANALYTIC_ADDRESS" ]; then
    sed -i "/upstream wallarm_wstore {/,/}/s/server 127.0.0.1/server ${POSTANALYTIC_ADDRESS}/" /etc/nginx/nginx.conf
  fi

  read -r NGX_CONF_FIRST < /etc/nginx/nginx.conf
  if [ "$NGX_CONF_FIRST" = "### Wallarm default ###" ] \
    || [ -n "$RENDER_STATUS_PAGE" ]; then
    echo "Rendering status page..."
    gomplate -f /opt/wallarm/wallarm-status.conf.tmpl > /etc/nginx/conf.d/wallarm-status.conf
  else
    echo "Custom nginx.conf (probably mounted dir), please handle status page manually"
  fi

  if [ -n "$NGINX_EXTERNAL_CONFIG" ]; then
     return 0
  fi

  if [ x"${WALLARM_NGINX_LOG_TO_FILES}" != x"true" ]
  then
    ln -sf /dev/stdout /var/log/nginx/access.log
    ln -sf /dev/stderr /var/log/nginx/error.log
  fi

  [ -n "$NGINX_BACKEND" ] || return 0

  echo "Rendering nginx default config..."
  gomplate -f /opt/wallarm/default.conf.tmpl > /etc/nginx/http.d/default.conf
}

configure_services() {
  if [ x"$POSTANALYTIC_ONLY" = x"true" ] \
    || [ x"$POSTANALYTIC_ONLY" = x"True" ] \
    || [ x"$POSTANALYTIC_ONLY" = x"yes" ]
  then
    WD_CONFIG=/opt/wallarm/etc/wd.postanalytics.yaml
    sed -i -e "s|127.0.0.1:3313|0.0.0.0:3313|g"  /opt/wallarm/wstore/wstore.yaml
    sed -i -e "s|127.0.0.1:6388|0.0.0.0:6388|g"  /opt/wallarm/wstore/wstore.yaml
    sed -i -e "s|127.0.0.1:9001|0.0.0.0:9001|g"  /opt/wallarm/wstore/wstore.yaml
  elif [ -n "$POSTANALYTIC_ADDRESS" ]; then
    WD_CONFIG=/opt/wallarm/etc/wd.filtering.yaml
  else
    WD_CONFIG=/opt/wallarm/etc/wd.all.yaml
  fi

  if [ x"$WALLARM_APIFW_ENABLE" = x"false" ] \
    || [ x"$WALLARM_APIFW_ENABLE" = x"False" ]
  then
    # Disable api-firewall via wd selective component mode.
    # Explicitly list all other processes so selective mode enables them only.
    if [ -n "$POSTANALYTIC_ADDRESS" ]; then
      # filtering mode: only wcli
      export WALLARM_WD__COMPONENT_WCLI=true
    else
      # all mode: wstore + wcli
      export WALLARM_WD__COMPONENT_WSTORE=true
      export WALLARM_WD__COMPONENT_WCLI=true
    fi
    sed -i -e '/wallarm-apifw-loc/d' \
      /etc/nginx/nginx.conf
  fi
}

# Translate WALLARM_API_* env vars to wd node config overrides.
# This preserves backward compatibility with existing deployments.
apply_api_env_overrides() {
  [ -n "$WALLARM_API_HOST" ] && export WALLARM_WD__NODE__HOST="$WALLARM_API_HOST"
  [ -n "$WALLARM_API_PORT" ] && export WALLARM_WD__NODE__PORT="$WALLARM_API_PORT"

  if [ x"$WALLARM_API_USE_SSL" = x"false" ] \
     || [ x"$WALLARM_API_USE_SSL" = x"False" ] \
     || [ x"$WALLARM_API_USE_SSL" = x"no" ]
  then
    export WALLARM_WD__NODE__USE_SSL=false
  fi

  if [ x"$WALLARM_API_CA_VERIFY" = x"false" ] \
     || [ x"$WALLARM_API_CA_VERIFY" = x"False" ] \
     || [ x"$WALLARM_API_CA_VERIFY" = x"no" ]
  then
    export WALLARM_WD__NODE__CA_VERIFY=false
  fi
}

if [ "${1}" = "--source-only" ]
then
  return
fi

if [ x"$WALLARM_FALLBACK" = x"false" ]
then
  set -e
fi

if [ "x${SLAB_ALLOC_ARENA}" = 'x' ]; then
  if [ -n "$TARANTOOL_MEMORY_GB" ]; then
    SLAB_ALLOC_ARENA=$TARANTOOL_MEMORY_GB
    export SLAB_ALLOC_ARENA
  fi
fi

if [ -n "$POSTANALYTIC_ADDRESS" ] && [ -n "$POSTANALYTIC_ONLY" ]; then
  echo "ERROR: noooo you can't just set postanalytic and filtering type at the same time..."

  exit 1
fi

if [ -z "$WALLARM_API_TOKEN" ]; then
  if [ ! -f "/opt/wallarm/etc/wallarm/private.key" ]; then
    echo "ERROR: no WALLARM_API_TOKEN and no private key in /etc/wallarm/private.key" >&2
    exit 1
  fi
fi

# Propagate env vars to wd child processes
set -a && source /opt/wallarm/env.list && set +a

printenv >> /etc/environment
configure_services
apply_api_env_overrides
configure_nginx

if [ x"$POSTANALYTIC_ONLY" = x"true" ] \
  || [ x"$POSTANALYTIC_ONLY" = x"True" ] \
  || [ x"$POSTANALYTIC_ONLY" = x"yes" ]
then
  exec /opt/wallarm/usr/bin/wd --config "$WD_CONFIG"
else
  /opt/wallarm/usr/bin/wd --config "$WD_CONFIG" &
  /opt/wallarm/usr/bin/wd --config "$WD_CONFIG" ctl status --wait-init
  exec /usr/sbin/nginx -g "daemon off;"
fi
